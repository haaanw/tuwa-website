---
import { useTranslations } from '../../i18n/utils';
import CJKLayout from '../../layouts/CJKLayout.astro';
import Hero from '../../components/Hero.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import StatsCounter from '../../components/StatsCounter.astro';
import LandingCTA from '../../components/LandingCTA.astro';

const t = useTranslations('zh');
---
<CJKLayout
  title={t.meta.title}
  description={t.meta.description}
>
  <Hero locale="zh" />
  <FeatureGrid locale="zh" />
  <StatsCounter locale="zh" />
  <LandingCTA locale="zh" />
</CJKLayout>
