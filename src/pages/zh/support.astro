---
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/700.css';
import { useSupportTranslations } from '../../i18n/utils';
import LegalPageLayout from '../../layouts/LegalPageLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';

const t = useSupportTranslations('zh');
---

<style is:global>
  :root { --font-sans: 'Noto Sans SC', 'General Sans Variable', system-ui, sans-serif; }
</style>

<LegalPageLayout title={t.meta.title} locale="zh">
  <FaqAccordion locale="zh" />

  <section style="margin-top: var(--space-2xl);">
    <h2 style="font-size: var(--text-heading); font-weight: var(--weight-heading); line-height: var(--leading-heading); letter-spacing: var(--tracking-heading); color: var(--color-text-1);">
      {t.contact.heading}
    </h2>
    <p style="margin-top: var(--space-md); color: var(--color-text-2); line-height: var(--leading-body);">
      {t.contact.subtext}
    </p>
    <p style="margin-top: var(--space-md);">
      <a href="mailto:hanwenma09@gmail.com" style="display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-sm) var(--space-md); background-color: var(--color-accent); color: var(--color-accent-fg); border-radius: var(--radius-md); text-decoration: none; font-weight: var(--weight-label); min-height: 44px;">
        {t.contact.buttonLabel}
      </a>
    </p>
    <p style="margin-top: var(--space-sm); font-size: var(--text-label); color: var(--color-text-3);">
      {t.contact.responseTime}
    </p>
  </section>
</LegalPageLayout>
