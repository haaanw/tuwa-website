---
import BaseLayout from './BaseLayout.astro';
import ScreenshotBlock from '../components/ScreenshotBlock.astro';
import FeatureCTA from '../components/FeatureCTA.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  screenshot?: ImageMetadata;
  screenshotAlt: string;
  outcomeStatement: string;
  hookLine: string;
}

const { title, description, ogImage, screenshot, screenshotAlt, outcomeStatement, hookLine } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- Hero -->
  <section data-animate style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
    <div class="mx-auto text-center" style="max-width: 768px; padding: 0 var(--space-md);">
      <h1
        style="
          font-size: var(--text-display);
          font-weight: 600;
          line-height: var(--leading-display);
          letter-spacing: var(--tracking-display);
          color: var(--color-text-1);
        "
      >
        {outcomeStatement}
      </h1>
      <p
        class="mx-auto"
        style="
          margin-top: var(--space-lg);
          max-width: 560px;
          font-size: var(--text-body);
          line-height: var(--leading-body);
          color: var(--color-text-2);
        "
      >
        {hookLine}
      </p>
    </div>
  </section>

  <!-- Screenshot -->
  <section data-animate style="padding-bottom: var(--space-3xl);">
    <ScreenshotBlock src={screenshot} alt={screenshotAlt} placeholderLabel={`${title} Screenshot — coming soon`} />
  </section>

  <!-- Explanation + Science — page-specific content via slot -->
  <slot />

  <!-- CTA -->
  <FeatureCTA />
</BaseLayout>
