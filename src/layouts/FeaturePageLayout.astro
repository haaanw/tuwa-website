---
import BaseLayout from './BaseLayout.astro';
import DeviceFrame from '../components/DeviceFrame.astro';
import FeatureCTA from '../components/FeatureCTA.astro';
import MatisseDecoration from '../components/MatisseDecoration.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  screenshot?: ImageMetadata;
  screenshotAlt: string;
  outcomeStatement: string;
  hookLine: string;
  shapeId?: 'blob-1' | 'blob-2' | 'blob-3' | 'blob-4' | 'blob-5' | 'blob-6' | 'blob-7';
}

const { title, description, ogImage, screenshot, screenshotAlt, outcomeStatement, hookLine, shapeId = 'blob-1' } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- Hero -->
  <section data-animate style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl); position: relative;">
    <div class="mx-auto text-center" style="width: 100%; max-width: 768px; box-sizing: border-box; padding: 0 var(--space-md); position: relative; z-index: 1;">
      <h1
        style="
          font-size: var(--text-display);
          font-weight: var(--weight-heading);
          line-height: var(--leading-display);
          letter-spacing: var(--tracking-display);
          color: var(--color-text-1);
        "
      >
        {outcomeStatement}
      </h1>
      <p
        class="mx-auto"
        style="
          margin-top: var(--space-lg);
          max-width: 560px;
          font-size: var(--text-body);
          line-height: var(--leading-body);
          color: var(--color-text-2);
        "
      >
        {hookLine}
      </p>
    </div>
    <MatisseDecoration shapeId={shapeId} />
  </section>

  <!-- Screenshot -->
  <section data-animate style="padding-bottom: var(--space-3xl);">
    <DeviceFrame src={screenshot} alt={screenshotAlt} placeholderLabel="Coming soon" />
  </section>

  <!-- Explanation + Science — page-specific content via slot -->
  <slot />

  <!-- CTA -->
  <FeatureCTA />
</BaseLayout>
