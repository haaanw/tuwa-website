---
import BaseLayout from './BaseLayout.astro';
import DeviceFrame from '../components/DeviceFrame.astro';
import FeatureCTA from '../components/FeatureCTA.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  screenshot?: ImageMetadata;
  screenshotAlt: string;
  outcomeStatement: string;
  hookLine: string;
}

const { title, description, ogImage, screenshot, screenshotAlt, outcomeStatement, hookLine } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- Hero -->
  <section data-animate style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
    <div class="mx-auto text-center" style="max-width: 768px; padding: 0 var(--space-md);">
      <h1
        style="
          font-size: var(--text-display);
          font-weight: var(--weight-heading);
          line-height: var(--leading-display);
          letter-spacing: var(--tracking-display);
          color: var(--color-text-1);
        "
      >
        {outcomeStatement}
      </h1>
      <p
        class="mx-auto"
        style="
          margin-top: var(--space-lg);
          max-width: 560px;
          font-size: var(--text-body);
          line-height: var(--leading-body);
          color: var(--color-text-2);
        "
      >
        {hookLine}
      </p>
    </div>
  </section>

  <!-- Screenshot -->
  <section data-animate style="padding-bottom: var(--space-3xl);">
    <DeviceFrame src={screenshot} alt={screenshotAlt} placeholderLabel="Coming soon" />
  </section>

  <!-- Standard content slot (How it works, overview) -->
  <slot />

  <!-- Coach vs Athlete perspective sections (coaching-specific) -->
  <section
    data-animate
    style="background-color: var(--color-surface); border-top: 1px solid var(--color-divider);"
  >
    <div class="mx-auto max-w-6xl px-6" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <slot name="coach-athlete" />
    </div>
  </section>

  <!-- Team features section (coaching-specific) -->
  <section data-animate>
    <div class="mx-auto max-w-6xl px-6" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <slot name="team-features" />
    </div>
  </section>

  <!-- Invite flow section (coaching-specific) -->
  <section
    data-animate
    style="background-color: var(--color-surface); border-top: 1px solid var(--color-divider);"
  >
    <div class="mx-auto max-w-6xl px-6" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <slot name="invite-flow" />
    </div>
  </section>

  <!-- CTA -->
  <FeatureCTA />
</BaseLayout>
