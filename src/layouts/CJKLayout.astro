---
// Layout for the zh home page. Loads CJK fonts via CJKFonts (imported only by
// zh pages, so the ~235KB unicode-range CSS never ships to EN/FR pages).
import BaseLayout from './BaseLayout.astro';
import CJKFonts from '../components/CJKFonts.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  type?: string;
}

const props = Astro.props;
---
<BaseLayout {...props} locale="zh">
  <CJKFonts slot="head" />
  <slot />
</BaseLayout>
