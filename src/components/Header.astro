---
import MobileMenu from "./MobileMenu.astro";
---
<header
  class="sticky top-0 z-50 border-b"
  style="
    height: 64px;
    background-color: color-mix(in srgb, var(--color-surface) 95%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-color: var(--color-divider);
  "
>
  <nav
    class="mx-auto flex h-full max-w-6xl items-center justify-between px-6"
    aria-label="Main navigation"
  >
    <!-- Logo — use <a>, NOT <h1> (accessibility: h1 is in main content) -->
    <a
      href="/"
      aria-label="Tuwa home"
      style="font-size: var(--text-heading); font-weight: 600; color: var(--color-text-1); letter-spacing: var(--tracking-heading); text-decoration: none;"
    >
      Tuwa
    </a>

    <!-- Desktop nav links (hidden on mobile) -->
    <ul class="hidden items-center gap-8 md:flex" role="list">
      <li class="relative" id="features-dropdown">
        <button
          type="button"
          class="flex items-center gap-1 transition-colors duration-100"
          style="color: var(--color-text-1); background: none; border: none; cursor: pointer; font: inherit;"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Features
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform duration-150" style="margin-top: 1px;">
            <polyline points="2,4 6,8 10,4" />
          </svg>
        </button>
        <ul
          role="list"
          class="absolute hidden"
          style="
            top: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%);
            min-width: 200px;
            background-color: var(--color-surface);
            border: 1px solid var(--color-divider);
            border-radius: var(--radius-md);
            padding: var(--space-xs) 0;
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
          "
        >
          <li><a href="/features/recovery-scoring" style="display: block; padding: var(--space-sm) var(--space-md); color: var(--color-text-2); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)';this.style.backgroundColor='var(--color-surface-2)'" onmouseout="this.style.color='var(--color-text-2)';this.style.backgroundColor='transparent'">Recovery Scoring</a></li>
          <li><a href="/features/workload-tracking" style="display: block; padding: var(--space-sm) var(--space-md); color: var(--color-text-2); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)';this.style.backgroundColor='var(--color-surface-2)'" onmouseout="this.style.color='var(--color-text-2)';this.style.backgroundColor='transparent'">Workload Tracking</a></li>
          <li><a href="/features/smart-templates" style="display: block; padding: var(--space-sm) var(--space-md); color: var(--color-text-2); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)';this.style.backgroundColor='var(--color-surface-2)'" onmouseout="this.style.color='var(--color-text-2)';this.style.backgroundColor='transparent'">Smart Templates</a></li>
          <li><a href="/features/cold-start" style="display: block; padding: var(--space-sm) var(--space-md); color: var(--color-text-2); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)';this.style.backgroundColor='var(--color-surface-2)'" onmouseout="this.style.color='var(--color-text-2)';this.style.backgroundColor='transparent'">Cold Start Solution</a></li>
          <li><a href="/features/coaching" style="display: block; padding: var(--space-sm) var(--space-md); color: var(--color-text-2); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)';this.style.backgroundColor='var(--color-surface-2)'" onmouseout="this.style.color='var(--color-text-2)';this.style.backgroundColor='transparent'">Coaching</a></li>
        </ul>
      </li>
      <li>
        <a href="/blog" class="transition-colors duration-100" style="color: var(--color-text-1); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-1)'">
          Blog
        </a>
      </li>
      <li>
        <a href="/support" class="transition-colors duration-100" style="color: var(--color-text-1); text-decoration: none;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-1)'">
          Support
        </a>
      </li>
    </ul>

    <!-- CTA button — accent color (D-02), hidden on mobile -->
    <a
      href="https://apps.apple.com/app/tuwa"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center transition-colors duration-100"
      style="
        background-color: var(--color-accent);
        color: var(--color-accent-fg);
        border-radius: var(--radius-md);
        padding: var(--space-sm) var(--space-md);
        font-weight: 600;
        text-decoration: none;
        font-size: var(--text-body);
      "
      onmouseover="this.style.backgroundColor='var(--color-accent-hover)';this.style.boxShadow='0 2px 8px rgba(43,82,64,0.20)'"
      onmouseout="this.style.backgroundColor='var(--color-accent)';this.style.boxShadow='none'"
    >
      Get the App
    </a>

    <!-- Mobile hamburger button (visible below md breakpoint) -->
    <button
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
      class="flex items-center justify-center md:hidden"
      style="width: 44px; height: 44px; background: none; border: none; cursor: pointer; color: var(--color-text-1);"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>
</header>

<MobileMenu />

<!-- Features dropdown toggle -->
<script is:inline>
  (function() {
    var dropdown = document.getElementById('features-dropdown');
    if (!dropdown) return;
    var btn = dropdown.querySelector('button');
    var menu = dropdown.querySelector('ul');
    var chevron = btn.querySelector('svg');

    btn.addEventListener('click', function() {
      var open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', !open);
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    });

    document.addEventListener('click', function(e) {
      if (!dropdown.contains(e.target)) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        chevron.style.transform = '';
      }
    });
  })();
</script>

<!-- Scroll shadow: subtle box-shadow when scrolled past top -->
<script is:inline>
  (function() {
    const header = document.querySelector("header");
    const sentinel = document.createElement("div");
    sentinel.style.height = "1px";
    sentinel.style.position = "absolute";
    sentinel.style.top = "0";
    document.body.prepend(sentinel);
    const observer = new IntersectionObserver(
      ([entry]) => {
        header.style.boxShadow = entry.isIntersecting
          ? "none"
          : "0 1px 0 var(--color-divider)";
      },
      { threshold: 1 }
    );
    observer.observe(sentinel);
  })();
</script>
