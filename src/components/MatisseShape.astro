---
/**
 * MatisseShape — renders one Swimming Pool-inspired movement mark.
 *
 * This component renders a `<path>` element inside the parent `<svg>`.
 * If an SVG transform is provided, it wraps the path in a `<g>` so CSS
 * animation transforms do not overwrite the authored placement.
 *
 * Shapes are original spontaneous dancer/swimmer gestures inspired by the
 * movement rhythm of Henri Matisse's The Swimming Pool, without tracing the
 * source artwork or drawing literal anatomy. The contours intentionally keep
 * a few uneven "scissor cut" kinks so they feel handmade.
 */

interface Props {
  shapeId: 'blob-1' | 'blob-2' | 'blob-3' | 'blob-4' | 'blob-5' | 'blob-6' | 'blob-7';
  fill?: string;
  opacity?: number;
  transform?: string;
  parallaxSpeed?: 'slow' | 'fast' | 'none';
  animateDelay?: string;
  class?: string;
}

const SHAPES: Record<string, string> = {
  'blob-1':
    'M14 158c27-38 62-62 106-73 22-5 46-31 68-74 16 36 4 64-36 86 29 9 57 28 83 56-37 12-72 5-106-21-13 22-37 48-72 76-22 4-39-3-51-20 26-18 49-42 70-70-20 2-41 15-62 40Z M88 50c17-21 39-31 66-28-13 22-34 39-64 51-11-7-12-15-2-23Z',
  'blob-2':
    'M26 169c2-41 28-72 77-93 31-13 52-33 63-61 17 24 12 51-16 78 26 3 54 24 84 62-41 8-78-3-110-34-7 36-27 66-61 91-21-8-32-23-33-45 17-11 37-26 58-47-24 7-45 24-62 49Z M130 60c22-31 50-47 82-47-9 30-32 51-68 65-13-1-17-7-14-18Z',
  'blob-3':
    'M9 123c43-36 86-51 129-43 29 5 56-9 83-43 0 43-21 68-64 77 19 22 45 40 78 55-39 15-76 5-113-30-30 19-67 34-110 46-9-24-10-45-3-62Z M77 60c-26 8-49 5-69-9 27-23 57-31 91-24 9 16 2 27-22 33Z',
  'blob-4':
    'M71 28c32 10 54 39 66 88 8 31 30 53 66 66-35 18-67 2-95-47-19 24-45 41-78 51-14-17-15-37-2-58 30-5 53-18 68-38-22-14-47-32-74-55 18-15 35-18 49-7Z M126 86c24-28 52-51 83-69 3 39-13 69-48 89-23 7-35 1-35-20Z',
  'blob-5':
    'M6 132c42-49 90-71 144-65 31 3 60-11 88-42-4 44-27 70-70 78 28 23 60 34 96 35-27 27-69 33-126 17-20 27-48 48-85 64-26-6-43-20-51-43 36-9 67-28 93-58-30 6-60 10-89 14Z M169 51c18-29 40-43 68-42-8 29-29 49-62 59-12-1-14-7-6-17Z',
  'blob-6':
    'M41 69c31-28 67-27 109 5 24 18 54 22 88 12-8 36-39 55-93 54 5 38-8 70-38 96-24-14-38-36-42-66 20-9 34-24 43-45-32 13-66 34-102 63-13-26-10-50 11-72 22-20 30-36 24-47Z M73 37c22-25 49-36 84-33-18 30-45 47-81 51-9-4-10-10-3-18Z',
  'blob-7':
    'M32 176c17-47 50-77 98-88 33-8 58-34 75-76 21 36 13 69-24 101 24 16 54 29 91 39-35 31-80 30-136-4-29 27-65 44-109 50-7-7-5-15 5-22Z M82 82c-34 5-64-3-92-24 39-22 74-29 106-19 9 18 4 33-14 43Z',
};

const {
  shapeId,
  fill = '#1E5B9A',
  opacity = 1,
  transform,
  parallaxSpeed = 'none',
  animateDelay = '0ms',
  class: className,
} = Astro.props;
---

{transform ? (
  <g transform={transform}>
    <path
      class:list={["matisse-shape", className]}
      fill={fill}
      fill-opacity={opacity}
      d={SHAPES[shapeId]}
      data-parallax-slow={parallaxSpeed === 'slow' ? '' : undefined}
      data-parallax-fast={parallaxSpeed === 'fast' ? '' : undefined}
      style={`animation-delay: ${animateDelay}`}
    />
  </g>
) : (
  <path
    class:list={["matisse-shape", className]}
    fill={fill}
    fill-opacity={opacity}
    d={SHAPES[shapeId]}
    data-parallax-slow={parallaxSpeed === 'slow' ? '' : undefined}
    data-parallax-fast={parallaxSpeed === 'fast' ? '' : undefined}
    style={`animation-delay: ${animateDelay}`}
  />
)}
