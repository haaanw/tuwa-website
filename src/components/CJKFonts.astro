---
// Noto Sans SC for CJK glyph rendering on Chinese pages.
// Imported here (not in BaseLayout) so the ~235KB unicode-range-subsetted CSS
// only ships to pages that render this component (locale === 'zh').
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/700.css';
---
<style is:global>
  /* html[lang="zh"] (specificity 0,1,1) beats global.css :root (0,1,0).
     General Sans stays first to keep Latin text in the brand typeface;
     CJK glyphs fall through to Noto Sans SC. */
  html[lang="zh"] {
    --font-general-sans: 'General Sans', 'Noto Sans SC', system-ui, sans-serif;
  }
</style>
