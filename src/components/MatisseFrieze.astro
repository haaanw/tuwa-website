---
/**
 * MatisseFrieze — hero background frieze inspired by The Swimming Pool.
 *
 * Renders as a full-width SVG band positioned absolutely behind hero content.
 * Uses the Phase 11 `.matisse-frieze` CSS stub for positioning and overflow.
 *
 * The Swimming Pool reference is a long wall-like frieze of blue cut-paper
 * swimmer/dancer gestures. The composition is intentionally syncopated, like
 * jazz phrasing: off-beat spacing, abrupt scale changes, improvised leaps,
 * and rough handmade edges.
 *
 * Shapes animate on page load (not IO-triggered — above fold).
 * Parallax activates via CSS @supports(animation-timeline: scroll()).
 */
import MatisseShape from './MatisseShape.astro';
---

<div class="matisse-frieze matisse-pool-frieze" style="height: 430px; top: 430px; bottom: auto;" aria-hidden="true">
  <svg
    viewBox="0 0 1440 360"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    style="width: 100%; height: 100%;"
  >
    <defs>
      <filter id="matisse-pool-brush-wobble" x="-4%" y="-18%" width="108%" height="136%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.012 0.09"
          numOctaves="2"
          seed="11"
          result="brushNoise"
        />
        <feDisplacementMap
          in="SourceGraphic"
          in2="brushNoise"
          scale="5"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>
    </defs>
    <path
      class="matisse-pool-band"
      filter="url(#matisse-pool-brush-wobble)"
      d="M-58 78C26 63 91 78 168 69C236 61 287 76 354 67C505 47 615 79 760 76C909 73 1049 50 1201 67C1316 80 1398 77 1498 63L1492 288C1384 301 1298 287 1198 299C1047 317 901 282 754 293C610 304 485 310 342 294C193 277 72 303 -58 291Z"
    />
    <path
      class="matisse-brush-edge matisse-brush-edge-top"
      filter="url(#matisse-pool-brush-wobble)"
      d="M-42 77C82 54 175 82 312 66C469 48 589 78 742 74C892 70 1043 50 1199 67C1313 80 1400 75 1494 61"
    />
    <path
      class="matisse-brush-edge matisse-brush-edge-bottom"
      filter="url(#matisse-pool-brush-wobble)"
      d="M-48 288C82 304 194 276 342 293C486 310 611 304 754 294C902 283 1047 317 1199 298C1300 286 1385 301 1491 287"
    />
    <path
      class="matisse-brush-fray"
      d="M-8 76C28 70 56 74 92 68 M246 69C286 60 318 67 362 63 M476 61C522 56 558 65 604 62 M944 64C990 56 1028 59 1077 55 M1298 70C1342 64 1384 66 1428 58"
    />
    <path
      class="matisse-brush-fray matisse-brush-fray-bottom"
      d="M70 292C110 299 148 288 190 294 M392 294C438 302 486 290 535 296 M672 292C716 286 758 294 804 289 M1058 302C1110 309 1158 293 1214 299 M1320 292C1370 287 1418 294 1470 285"
    />
    <path
      class="matisse-brush-streak"
      d="M54 123C170 108 278 130 402 118C530 106 616 123 738 120"
    />
    <path
      class="matisse-brush-streak matisse-brush-streak-short"
      d="M842 112C934 100 1021 118 1110 108C1205 97 1298 108 1382 98"
    />
    <path
      class="matisse-brush-streak matisse-brush-streak-low"
      d="M128 245C260 262 374 238 510 249C634 259 740 239 878 252C988 262 1104 246 1240 255"
    />
    <MatisseShape
      shapeId="blob-1"
      fill="#1E5B9A"
      opacity={0.84}
      transform="translate(-78, 122) rotate(18) scale(0.82)"
      parallaxSpeed="slow"
      animateDelay="0ms"
    />
    <MatisseShape
      shapeId="blob-4"
      fill="#2D78BA"
      opacity={0.72}
      transform="translate(72, 48) rotate(-31) scale(0.70)"
      parallaxSpeed="fast"
      animateDelay="80ms"
    />
    <MatisseShape
      shapeId="blob-2"
      fill="#174A82"
      opacity={0.88}
      transform="translate(220, 138) rotate(28) scale(1.02)"
      parallaxSpeed="slow"
      animateDelay="160ms"
    />
    <MatisseShape
      shapeId="blob-6"
      fill="#1E5B9A"
      opacity={0.76}
      transform="translate(430, 76) rotate(-18) scale(0.68)"
      parallaxSpeed="fast"
      animateDelay="240ms"
    />
    <MatisseShape
      shapeId="blob-3"
      fill="#2D78BA"
      opacity={0.86}
      transform="translate(565, 124) rotate(7) scale(1.06)"
      parallaxSpeed="slow"
      animateDelay="320ms"
    />
    <MatisseShape
      shapeId="blob-7"
      fill="#174A82"
      opacity={0.74}
      transform="translate(785, 52) rotate(24) scale(0.78)"
      parallaxSpeed="fast"
      animateDelay="400ms"
    />
    <MatisseShape
      shapeId="blob-5"
      fill="#1E5B9A"
      opacity={0.84}
      transform="translate(930, 146) rotate(-32) scale(0.92)"
      parallaxSpeed="slow"
      animateDelay="480ms"
    />
    <MatisseShape
      shapeId="blob-2"
      fill="#1E5B9A"
      opacity={0.70}
      transform="translate(1090, 78) rotate(-6) scale(0.70)"
      parallaxSpeed="fast"
      animateDelay="560ms"
    />
    <MatisseShape
      shapeId="blob-4"
      fill="#2D78BA"
      opacity={0.84}
      transform="translate(1224, 118) rotate(31) scale(0.92)"
      parallaxSpeed="slow"
      animateDelay="640ms"
    />
    <MatisseShape
      shapeId="blob-1"
      fill="#174A82"
      opacity={0.68}
      transform="translate(1405, 66) rotate(-24) scale(0.76)"
      parallaxSpeed="fast"
      animateDelay="720ms"
    />
  </svg>
</div>
