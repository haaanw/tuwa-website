---
/**
 * MatisseFrieze — hero section background frieze with 7 biomorphic shapes.
 *
 * Renders as a full-width SVG band positioned absolutely behind hero content.
 * Uses the Phase 11 `.matisse-frieze` CSS stub for positioning and overflow.
 *
 * Color distribution (D-11, D-12):
 *   - 5 shapes: accent green #2B5240
 *   - 1 shape: terracotta #8B5E3C
 *   - 1 shape: soft gold #A89060
 *
 * Shapes animate on page load (not IO-triggered — above fold).
 * Parallax activates via CSS @supports(animation-timeline: scroll()).
 */
import MatisseShape from './MatisseShape.astro';
---

<div class="matisse-frieze" style="height: 240px; top: auto; bottom: 30%;" aria-hidden="true">
  <svg
    viewBox="0 0 1440 240"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    style="width: 100%; height: 100%; overflow: visible;"
  >
    <MatisseShape
      shapeId="blob-1"
      fill="#2B5240"
      opacity={0.95}
      transform="translate(80, 40) rotate(-12) scale(1.5)"
      parallaxSpeed="slow"
      animateDelay="0ms"
    />
    <MatisseShape
      shapeId="blob-2"
      fill="#8B5E3C"
      opacity={0.90}
      transform="translate(300, 80) rotate(8) scale(1.1)"
      parallaxSpeed="fast"
      animateDelay="80ms"
    />
    <MatisseShape
      shapeId="blob-3"
      fill="#2B5240"
      opacity={0.92}
      transform="translate(520, 30) rotate(-5) scale(1.6)"
      parallaxSpeed="slow"
      animateDelay="160ms"
    />
    <MatisseShape
      shapeId="blob-4"
      fill="#A89060"
      opacity={0.88}
      transform="translate(720, 70) rotate(15) scale(1.0)"
      parallaxSpeed="fast"
      animateDelay="240ms"
    />
    <MatisseShape
      shapeId="blob-5"
      fill="#2B5240"
      opacity={0.94}
      transform="translate(920, 50) rotate(-8) scale(1.3)"
      parallaxSpeed="slow"
      animateDelay="320ms"
    />
    <MatisseShape
      shapeId="blob-6"
      fill="#2B5240"
      opacity={0.91}
      transform="translate(1120, 60) rotate(10) scale(1.4)"
      parallaxSpeed="fast"
      animateDelay="400ms"
    />
    <MatisseShape
      shapeId="blob-7"
      fill="#2B5240"
      opacity={0.93}
      transform="translate(1300, 35) rotate(-15) scale(1.2)"
      parallaxSpeed="slow"
      animateDelay="480ms"
    />
  </svg>
</div>
