---
import dashboardScreenshot from '../assets/screenshots/dashboard.png';
import DeviceFrame from './DeviceFrame.astro';
import MatisseFrieze from './MatisseFrieze.astro';
import { APP_STORE_URL } from '../config';
import { useHomeTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useHomeTranslations(locale);
---

<section class="section-spaced px-6" style="position: relative;">
  <MatisseFrieze />
  <div class="mx-auto text-center" style="width: 100%; max-width: 768px; position: relative; z-index: 1;">

    <!-- Headline — h1 (one per page, per accessibility contract) -->
    <h1
      class="hero-headline"
      style="
        font-weight: var(--weight-display);
        line-height: var(--leading-display);
        letter-spacing: var(--tracking-display);
        color: var(--color-text-1);
      "
    >
      {t.hero.headline}
    </h1>

    <!-- Subtitle -->
    <p
      class="hero-subtitle mx-auto"
      style="
        margin-top: var(--space-lg);
        max-width: 560px;
        font-size: var(--text-body);
        line-height: var(--leading-body);
        color: var(--color-text-2);
      "
    >
      {t.hero.subtitle}
    </p>

    <!-- Device mockup — CSS iPhone frame with subtle perspective tilt (D-05) -->
    <div
      class="hero-device relative mx-auto"
      style="
        margin-top: var(--space-2xl);
        max-width: 320px;
      "
    >
      <DeviceFrame
        src={dashboardScreenshot}
        alt={t.hero.deviceAlt}
        loading="eager"
        fetchpriority="high"
        widths={[320, 640, 960]}
      />
    </div>

    <!-- App Store badge — above the fold, per D-01/D-02 -->
    <div class="flex justify-center" style="margin-top: var(--space-xl);">
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.hero.badgeAriaLabel}
        class="inline-block"
      >
        <img
          src="/badges/app-store-badge.svg"
          alt={t.hero.badgeAlt}
          height="40"
          width="120"
          loading="eager"
        />
      </a>
    </div>

  </div>
</section>
