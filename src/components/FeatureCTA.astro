---
import { APP_STORE_URL } from '../config';
---

<!-- Feature page CTA section — surface background for visual break from page bg -->
<section
  data-animate
  style="background-color: var(--color-surface); border-top: 1px solid var(--color-divider);"
>
  <div class="section-spaced mx-auto max-w-6xl px-6">
    <div class="mx-auto text-center" style="max-width: 640px;">

      <!-- Closing headline -->
      <h2
        style="
          font-size: var(--text-heading);
          font-weight: 600;
          line-height: var(--leading-heading);
          letter-spacing: var(--tracking-heading);
          color: var(--color-text-1);
        "
      >
        Start training with confidence
      </h2>

      <!-- Supporting copy -->
      <p
        style="
          margin-top: var(--space-lg);
          color: var(--color-text-2);
        "
      >
        Download Tuwa and take the guesswork out of recovery and load management.
      </p>

      <!-- App Store badge -->
      <div
        class="flex flex-col items-center"
        style="margin-top: var(--space-xl);"
      >
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download Tuwa on the App Store"
          class="btn-cta inline-block"
        >
          <img
            src="/badges/app-store-badge.svg"
            alt="Download on the App Store"
            height="44"
            width="148"
            loading="lazy"
          />
        </a>
      </div>

    </div>
  </div>
</section>
