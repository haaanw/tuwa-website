    />
    <path
      class="matisse-feature-brush-fray"
      d="M6 64C28 58 50 66 74 60 M132 61C160 54 186 64 214 58 M308 61C336 54 362 62 388 55"
    />
    <path
      class="matisse-feature-brush-fray matisse-feature-brush-fray-bottom"
      d="M18 226C48 235 78 221 108 228 M248 224C280 214 314 229 348 218"
    />
    <path
      class="matisse-feature-brush-streak"
      d="M24 116C82 104 136 122 194 112C246 103 300 118 366 108"
    />
    <path
      class="matisse-feature-brush-streak matisse-feature-brush-streak-low"
      d="M-18 178C36 190 92 168 152 182C224 198 292 171 414 184"
    />
    <g
      class="matisse-feature-daubs matisse-feature-mobile-daubs"
      filter="url(#matisse-feature-mobile-brush-wobble)"
      aria-hidden="true"
    >
      <path
        class="matisse-feature-daub matisse-feature-daub-deep matisse-feature-oil-mark"
        d="M54 106c16-11 41-10 55 3-10 14-37 18-54 8-7-4-6-8-1-11Z"
      />
      <path
        class="matisse-feature-paint-bristle matisse-feature-paint-bristle-light"
        d="M64 112c13-3 25-3 38 1"
      />
      <path
        class="matisse-feature-dot matisse-feature-dot-mid matisse-feature-oil-mark"
        d="M128 176c14-10 36-9 48 2-10 13-34 16-48 6-6-4-6-6 0-8Z"
      />
      <path
        class="matisse-feature-daub matisse-feature-daub-mid matisse-feature-oil-mark"
        d="M210 96c17-11 42-8 58 5-11 14-39 17-57 6-7-4-8-7-1-11Z"
      />
      <path
        class="matisse-feature-paint-bristle"
        d="M220 102c14-3 27-2 42 3"
      />
      <path
        class="matisse-feature-dot matisse-feature-oil-mark"
        d="M292 162c17-12 41-10 54 4-12 14-37 17-53 6-7-5-7-8-1-10Z"
      />
    </g>
    <MatisseShape
      shapeId={shapeId}
      fill="#1E5B9A"
      opacity={0.64}
      transform="translate(-34, 120) scale(0.36) rotate(18)"
      class="matisse-feature-shape"
    />
    <MatisseShape
      shapeId={secondaryShape}
      fill="#2D78BA"
      opacity={0.60}
      transform="translate(306, 118) scale(0.34) rotate(-24)"
      class="matisse-feature-shape"
    />
  </svg>
</div>
