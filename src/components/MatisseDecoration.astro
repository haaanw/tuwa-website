      />
      <path
        class="matisse-feature-dot matisse-feature-oil-mark"
        d="M914 92c25-18 64-16 84 3-16 22-58 28-82 12-11-7-12-11-2-15Z"
      />
      <path
        class="matisse-feature-paint-bristle"
        d="M928 100c19-5 39-4 58 2"
      />
      <path
        class="matisse-feature-daub matisse-feature-daub-deep matisse-feature-oil-mark"
        d="M1018 190c31-20 78-12 106 16-23 23-78 27-111 6-12-8-10-15 5-22Z"
      />
      <path
        class="matisse-feature-paint-bristle matisse-feature-paint-bristle-light"
        d="M1038 202c25-5 50-2 73 6"
      />
      <path
        class="matisse-feature-dot matisse-feature-dot-mid matisse-feature-oil-mark"
        d="M1278 154c17-13 45-12 59 2-11 15-41 19-58 7-7-5-7-7-1-9Z"
      />
      <path
        class="matisse-feature-daub matisse-feature-oil-mark"
        d="M1350 96c20-17 53-15 75 2-12 20-50 29-74 14-10-6-10-11-1-16Z"
      />
      <path
        class="matisse-feature-paint-bristle"
        d="M1363 104c17-4 35-3 52 3"
      />
    </g>
    <MatisseShape
      shapeId={shapeId}
      fill="#1E5B9A"
      opacity={0.78}
      transform="translate(18, 78) scale(0.60) rotate(18)"
      class="matisse-feature-shape"
    />
    <MatisseShape
      shapeId={secondaryShape}
      fill="#2D78BA"
      opacity={0.70}
      transform="translate(388, 70) scale(0.54) rotate(-24)"
      class="matisse-feature-shape"
    />
    <MatisseShape
      shapeId={tertiaryShape}
      fill="#174A82"
      opacity={0.74}
      transform="translate(802, 98) scale(0.62) rotate(12)"
      class="matisse-feature-shape"
    />
    <MatisseShape
      shapeId={fourthShape}
      fill="#1E5B9A"
      opacity={0.68}
      transform="translate(1160, 66) scale(0.56) rotate(-16)"
      class="matisse-feature-shape"
    />
    <MatisseShape
      shapeId={fifthShape}
      fill="#2D78BA"
      opacity={0.58}
      transform="translate(242, 130) scale(0.36) rotate(34)"
      class="matisse-feature-shape matisse-feature-shape-small"
    />
    <MatisseShape
      shapeId={sixthShape}
      fill="#174A82"
      opacity={0.54}
      transform="translate(1004, 140) scale(0.34) rotate(-28)"
      class="matisse-feature-shape matisse-feature-shape-small"
    />
  </svg>
  <svg
    class="matisse-feature-svg matisse-feature-svg-mobile"
    viewBox="0 0 390 260"
    preserveAspectRatio="none"
    width="100%"
    height="260"
    aria-hidden="true"
  >
    <defs>
      <filter id="matisse-feature-mobile-brush-wobble" x="-8%" y="-18%" width="116%" height="136%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.02 0.12"
          numOctaves="2"
          seed="23"
          result="featureMobileBrushNoise"
        />
        <feDisplacementMap
          in="SourceGraphic"
          in2="featureMobileBrushNoise"
          scale="3"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>
    </defs>
    <path
      class="matisse-feature-band"
      filter="url(#matisse-feature-mobile-brush-wobble)"
      d="M-24 64C28 52 78 69 130 60C182 51 224 65 274 62C320 59 356 61 414 50L414 218C356 230 318 212 273 224C224 237 181 221 130 226C77 231 28 240 -24 224Z"
    />
    <path
