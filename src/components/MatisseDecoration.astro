---
/**
 * MatisseDecoration — feature page fragments from the Swimming Pool system.
 *
 * Renders a subtle full-width strip in feature page hero sections.
 * Feature page shapes use the same blue cut-paper language, held just quieter
 * than the homepage hero.
 * Entrance is IO-triggered via data-animate + existing IntersectionObserver.
 */
import MatisseShape from './MatisseShape.astro';

interface Props {
  shapeId: 'blob-1' | 'blob-2' | 'blob-3' | 'blob-4' | 'blob-5' | 'blob-6' | 'blob-7';
  secondaryShapeId?: 'blob-1' | 'blob-2' | 'blob-3' | 'blob-4' | 'blob-5' | 'blob-6' | 'blob-7';
}

const { shapeId, secondaryShapeId } = Astro.props;

const allShapes = ['blob-1', 'blob-2', 'blob-3', 'blob-4', 'blob-5', 'blob-6', 'blob-7'] as const;
const secondaryShape = secondaryShapeId ?? allShapes.find((s) => s !== shapeId) ?? 'blob-2';
const tertiaryShape = allShapes.find((s) => s !== shapeId && s !== secondaryShape) ?? 'blob-3';
const fourthShape = allShapes.find((s) => s !== shapeId && s !== secondaryShape && s !== tertiaryShape) ?? 'blob-4';
const fifthShape =
  allShapes.find((s) => s !== shapeId && s !== secondaryShape && s !== tertiaryShape && s !== fourthShape) ??
  'blob-5';
const sixthShape =
  allShapes.find(
    (s) => s !== shapeId && s !== secondaryShape && s !== tertiaryShape && s !== fourthShape && s !== fifthShape,
  ) ?? 'blob-6';
---

<div
  class="matisse-decoration matisse-feature-strip"
  data-animate
  aria-hidden="true"
>
  <svg
    class="matisse-feature-svg matisse-feature-svg-desktop"
    viewBox="0 0 1440 260"
    preserveAspectRatio="xMidYMid slice"
    width="100%"
    height="260"
    aria-hidden="true"
  >
    <defs>
      <filter id="matisse-feature-brush-wobble" x="-4%" y="-20%" width="108%" height="140%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.014 0.12"
          numOctaves="2"
          seed="19"
          result="featureBrushNoise"
        />
        <feDisplacementMap
          in="SourceGraphic"
          in2="featureBrushNoise"
          scale="4"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>
    </defs>
    <path
      class="matisse-feature-band"
      filter="url(#matisse-feature-brush-wobble)"
      d="M-54 58C80 42 188 65 331 54C474 42 612 51 750 66C894 82 1032 44 1174 55C1300 65 1394 65 1495 48L1487 218C1370 231 1281 211 1172 226C1029 246 891 210 747 221C611 232 472 236 328 225C188 214 80 240 -54 220Z"
    />
    <path
      class="matisse-feature-brush-edge"
      filter="url(#matisse-feature-brush-wobble)"
      d="M-40 58C86 42 194 67 330 54C474 42 611 52 749 66C892 81 1032 44 1174 55C1300 66 1393 65 1494 48"
    />
    <path
      class="matisse-feature-brush-edge matisse-feature-brush-edge-bottom"
      filter="url(#matisse-feature-brush-wobble)"
      d="M-46 220C82 239 188 214 328 225C472 236 611 232 747 221C891 210 1029 246 1172 226C1281 211 1370 231 1487 218"
    />
    <path
      class="matisse-feature-brush-fray"
      d="M24 58C68 52 106 61 150 55 M304 54C354 46 398 55 446 51 M626 58C668 55 704 67 748 63 M1060 54C1110 46 1158 59 1204 53 M1328 56C1378 53 1422 58 1470 48"
    />
    <path
      class="matisse-feature-brush-fray matisse-feature-brush-fray-bottom"
      d="M74 221C124 232 170 215 220 224 M408 225C458 234 512 222 568 228 M828 222C880 214 934 229 986 220 M1162 227C1216 216 1270 226 1324 219"
    />
    <path
      class="matisse-feature-brush-streak"
      d="M68 109C185 94 285 118 410 106C542 95 650 110 770 116"
    />
    <path
      class="matisse-feature-brush-streak matisse-feature-brush-streak-low"
      d="M834 174C960 190 1068 164 1194 178C1292 188 1372 172 1468 184"
    />
    <g class="matisse-feature-daubs" filter="url(#matisse-feature-brush-wobble)" aria-hidden="true">
      <path
        class="matisse-feature-daub matisse-feature-daub-deep matisse-feature-oil-mark"
        d="M158 94c19-15 48-14 76-4 11 4 11 12 0 19-25 16-62 16-83 2-8-5-5-11 7-17Z"
      />
      <path
        class="matisse-feature-paint-bristle matisse-feature-paint-bristle-light"
        d="M170 101c18-5 37-5 57 0"
      />
      <path
        class="matisse-feature-daub matisse-feature-daub-mid matisse-feature-oil-mark"
        d="M272 181c26-17 69-12 98 9-19 24-70 30-101 10-11-7-10-13 3-19Z"
      />
      <path
        class="matisse-feature-paint-bristle"
        d="M294 190c18-6 38-5 62 3"
      />
      <path
        class="matisse-feature-dot matisse-feature-dot-deep matisse-feature-oil-mark"
        d="M488 86c18-14 45-13 64 1 8 6 6 14-5 21-23 13-55 11-68-5-5-6-2-12 9-17Z"
      />
      <path
        class="matisse-feature-paint-bristle matisse-feature-paint-bristle-light"
        d="M496 95c18-4 34-3 49 2"
      />
      <path
        class="matisse-feature-daub matisse-feature-oil-mark"
        d="M584 200c20-18 55-17 76 0-12 22-50 32-75 17-11-6-11-11-1-17Z"
      />
      <path
        class="matisse-feature-paint-bristle"
        d="M598 208c19-4 36-3 51 3"
      />
      <path
        class="matisse-feature-daub matisse-feature-daub-mid matisse-feature-oil-mark"
        d="M710 86c25-13 63-8 82 9-15 20-57 25-84 9-10-6-10-12 2-18Z"
      />
      <path
        class="matisse-feature-paint-bristle matisse-feature-paint-bristle-light"
