---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { APP_STORE_URL } from '../config';

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;
const year = new Date().getFullYear();
---
<footer style="background-color: var(--color-surface); border-top: 1px solid var(--color-divider);">
  <div class="mx-auto max-w-6xl px-6" style="padding-top: var(--space-2xl); padding-bottom: var(--space-xl);">
    <nav aria-label="Footer navigation">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">

        <!-- Brand column with App Store badge -->
        <div class="col-span-2 md:col-span-1">
          <a href={getRelativeLocaleUrl(locale, '/')} aria-label="Tuwa home" class="inline-block" style="font-size: var(--text-heading); font-weight: var(--weight-label); color: var(--color-text-1); letter-spacing: var(--tracking-heading);">
            Tuwa
          </a>
          <div style="margin-top: var(--space-lg);">
            <a
              href={APP_STORE_URL}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Download Tuwa on the App Store"
              class="inline-block"
            >
              <img
                src="/badges/app-store-badge.svg"
                alt="Download on the App Store"
                height="40"
                width="120"
                loading="lazy"
              />
            </a>
          </div>
        </div>

        <!-- Features column -->
        <div>
          <p style="color: var(--color-text-1); font-weight: var(--weight-body); margin-bottom: var(--space-sm);">Features</p>
          <ul role="list" class="space-y-2" style="color: var(--color-text-2);">
            <li><a href={getRelativeLocaleUrl(locale, '/features/recovery-scoring')} class="nav-link" style="color: var(--color-text-2);">Recovery Scoring</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/features/workload-tracking')} class="nav-link" style="color: var(--color-text-2);">Workload Tracking</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/features/smart-templates')} class="nav-link" style="color: var(--color-text-2);">Smart Templates</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/features/cold-start')} class="nav-link" style="color: var(--color-text-2);">Cold Start Solution</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/features/coaching')} class="nav-link" style="color: var(--color-text-2);">Coaching</a></li>
          </ul>
        </div>

        <!-- Resources column -->
        <div>
          <p style="color: var(--color-text-1); font-weight: var(--weight-body); margin-bottom: var(--space-sm);">Resources</p>
          <ul role="list" class="space-y-2" style="color: var(--color-text-2);">
            <li><a href={getRelativeLocaleUrl(locale, '/blog')} class="nav-link" style="color: var(--color-text-2);">Blog</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/support')} class="nav-link" style="color: var(--color-text-2);">Support</a></li>
          </ul>
        </div>

        <!-- Legal column -->
        <div>
          <p style="color: var(--color-text-1); font-weight: var(--weight-body); margin-bottom: var(--space-sm);">Legal</p>
          <ul role="list" class="space-y-2" style="color: var(--color-text-2);">
            <li><a href={getRelativeLocaleUrl(locale, '/privacy')} class="nav-link" style="color: var(--color-text-2);">Privacy Policy</a></li>
            <li><a href={getRelativeLocaleUrl(locale, '/terms')} class="nav-link" style="color: var(--color-text-2);">Terms of Service</a></li>
          </ul>
        </div>

      </div>
    </nav>

    <!-- Copyright -->
    <p style="margin-top: var(--space-2xl); color: var(--color-text-3); font-size: var(--text-label);">
      &copy; {year} Tuwa. All rights reserved.
    </p>
  </div>
</footer>
