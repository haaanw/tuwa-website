<!-- Feature navigation wheel — iPod-style SVG click wheel (Phase 08.1) -->
<!-- 5 feature segments: drag-to-rotate, click-to-select, keyboard navigation -->
<!-- Labels counter-rotate to stay upright. Buttons reposition on rotate. -->

<section class="section-spaced">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Section title -->
    <h2
      class="text-center"
      style="
        font-size: var(--text-heading);
        font-weight: 600;
        line-height: var(--leading-heading);
        letter-spacing: var(--tracking-heading);
        color: var(--color-text-1);
        margin-bottom: var(--space-xl);
      "
    >
      Everything you need to train without guessing
    </h2>

    <!-- Click wheel container -->
    <div
      class="wheel-container"
      id="feature-wheel"
      data-animate
      data-animate-delay="0ms"
      aria-label="Feature navigation wheel"
      role="group"
      tabindex="0"
    >
      <!-- SVG wheel: rim track + separate arc and label groups -->
      <svg
        id="feature-wheel-svg"
        class="wheel-svg"
        viewBox="0 0 480 480"
        style="touch-action: none;"
        aria-hidden="true"
      >
        <!-- Arcs group: rim track + arc paths rotate together -->
        <g id="wheel-arcs-group">
          <!-- Rim track background circle (rotates with arcs — circle is symmetric so rotation is invisible) -->
          <circle class="wheel-rim-track" cx="240" cy="240" r="190" />
          <!-- Segment 0: Recovery (12 o'clock) -->
          <path class="wheel-arc is-active" data-index="0"
            d="M 119.549 67.978 A 210 210 0 0 1 360.451 67.978 L 337.508 100.744 A 170 170 0 0 0 142.492 100.744 Z" />
          <!-- Segment 1: Workload (72 deg) -->
          <path class="wheel-arc" data-index="1"
            d="M 366.381 72.287 A 210 210 0 0 1 440.824 301.398 L 402.572 289.703 A 170 170 0 0 0 342.309 104.232 Z" />
          <!-- Segment 2: Templates (144 deg) -->
          <path class="wheel-arc" data-index="2"
            d="M 438.559 308.369 A 210 210 0 0 1 243.665 449.968 L 242.967 409.974 A 170 170 0 0 0 400.738 295.347 Z" />
          <!-- Segment 3: Cold-Start (216 deg) -->
          <path class="wheel-arc" data-index="3"
            d="M 236.335 449.968 A 210 210 0 0 1 41.441 308.369 L 79.262 295.347 A 170 170 0 0 0 237.033 409.974 Z" />
          <!-- Segment 4: Coaching (288 deg) -->
          <path class="wheel-arc" data-index="4"
            d="M 39.176 301.398 A 210 210 0 0 1 113.619 72.287 L 137.691 104.232 A 170 170 0 0 0 77.428 289.703 Z" />
        </g>

        <!-- Labels group: each billboard counter-rotates to stay upright -->
        <g id="wheel-labels-group">
          <!-- Seg 0: Recovery at (240, 50) -->
          <g class="wheel-segment-billboard" data-x="240" data-y="50">
            <g class="wheel-segment-content is-active" data-index="0">
              <svg class="wheel-segment-icon is-active" viewBox="0 0 24 24" width="20" height="20" x="230" y="32" aria-hidden="true">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <text class="wheel-segment-label is-active" x="240" y="57">RECOVERY</text>
            </g>
          </g>
          <!-- Seg 1: Workload at (420.701, 181.287) -->
          <g class="wheel-segment-billboard" data-x="420.701" data-y="181.287">
            <g class="wheel-segment-content" data-index="1">
              <svg class="wheel-segment-icon" viewBox="0 0 24 24" width="20" height="20" x="410.701" y="163.287" aria-hidden="true">
                <rect x="2" y="14" width="4" height="8" rx="1"/><rect x="9" y="9" width="4" height="13" rx="1"/><rect x="16" y="4" width="4" height="18" rx="1"/>
              </svg>
              <text class="wheel-segment-label" x="420.701" y="188.287">LOAD</text>
            </g>
          </g>
          <!-- Seg 2: Templates at (351.679, 393.713) -->
          <g class="wheel-segment-billboard" data-x="351.679" data-y="393.713">
            <g class="wheel-segment-content" data-index="2">
              <svg class="wheel-segment-icon" viewBox="0 0 24 24" width="20" height="20" x="341.679" y="375.713" aria-hidden="true">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7-1c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-1 14H7v-2h4v2zm0-4H7v-2h4v2zm0-4H7V6h4v2zm6 8h-4v-2h4v2zm0-4h-4v-2h4v2zm0-4h-4V6h4v2z"/>
              </svg>
              <text class="wheel-segment-label" x="351.679" y="400.713">TRAINING</text>
            </g>
          </g>
          <!-- Seg 3: Cold-Start at (128.321, 393.713) -->
          <g class="wheel-segment-billboard" data-x="128.321" data-y="393.713">
            <g class="wheel-segment-content" data-index="3">
              <svg class="wheel-segment-icon" viewBox="0 0 24 24" width="20" height="20" x="118.321" y="375.713" aria-hidden="true">
                <path d="M7 2v11h3v9l7-12h-4l4-8z"/>
              </svg>
              <text class="wheel-segment-label" x="128.321" y="400.713">ONBOARDING</text>
            </g>
          </g>
          <!-- Seg 4: Coaching at (59.299, 181.287) -->
          <g class="wheel-segment-billboard" data-x="59.299" data-y="181.287">
            <g class="wheel-segment-content" data-index="4">
              <svg class="wheel-segment-icon" viewBox="0 0 24 24" width="20" height="20" x="49.299" y="163.287" aria-hidden="true">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
              <text class="wheel-segment-label" x="59.299" y="188.287">COACHING</text>
            </g>
          </g>
        </g>
      </svg>

      <!-- Segment buttons: repositioned dynamically on rotate -->
      <button class="wheel-segment-btn" data-index="0" aria-pressed="true"
        style="left: 50%; top: 10.417%;"><span class="sr-only">Recovery Scoring</span></button>
      <button class="wheel-segment-btn" data-index="1" aria-pressed="false"
        style="left: 87.646%; top: 37.768%;"><span class="sr-only">Workload Tracking</span></button>
      <button class="wheel-segment-btn" data-index="2" aria-pressed="false"
        style="left: 73.266%; top: 82.024%;"><span class="sr-only">Smart Templates</span></button>
      <button class="wheel-segment-btn" data-index="3" aria-pressed="false"
        style="left: 26.734%; top: 82.024%;"><span class="sr-only">Cold-Start Onboarding</span></button>
      <button class="wheel-segment-btn" data-index="4" aria-pressed="false"
        style="left: 12.354%; top: 37.768%;"><span class="sr-only">Coach + Athlete</span></button>

      <!-- Center overlay: does NOT rotate, shows selected feature preview -->
      <div class="wheel-center">
        <div class="wheel-center-content" role="region" aria-live="polite">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <span class="wheel-center-title">Recovery Scoring</span>
          <span class="wheel-center-desc">HRV, sleep, heart rate, and training context synthesized into one daily readiness number.</span>
          <a class="wheel-center-link" href="/features/recovery-scoring" aria-label="Explore Recovery Scoring">Explore &#x2192;</a>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var wheel = document.getElementById('feature-wheel');
    if (!wheel) return;

    var svgEl = document.getElementById('feature-wheel-svg');
    var arcsGroup = document.getElementById('wheel-arcs-group');
    var billboards = wheel.querySelectorAll('.wheel-segment-billboard');
    var centerContent = wheel.querySelector('.wheel-center-content');
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var CX = 240;
    var CY = 240;
    var SEGMENT_ANGLE = 72;
    var MID_RADIUS = 190;
    var DEG2RAD = Math.PI / 180;

    var activeIndex = 0;
    var currentRotation = 0;
    var isDragging = false;
    var lastAngle = 0;
    var velocitySamples = [];
    var rafId = null;
    var dragDistance = 0;

    var features = [
      {
        title: 'Recovery Scoring',
        desc: 'HRV, sleep, heart rate, and training context synthesized into one daily readiness number.',
        href: '/features/recovery-scoring',
        iconSvg: '<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>'
      },
      {
        title: 'Workload Tracking',
        desc: 'Multi-factor fatigue tracking and load spike detection keep you in the optimal zone.',
        href: '/features/workload-tracking',
        iconSvg: '<rect x="2" y="14" width="4" height="8" rx="1"/><rect x="9" y="9" width="4" height="13" rx="1"/><rect x="16" y="4" width="4" height="18" rx="1"/>'
      },
      {
        title: 'Smart Templates',
        desc: 'Prescribed workouts with target sets, weight, and rep goals built in.',
        href: '/features/smart-templates',
        iconSvg: '<path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7-1c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-1 14H7v-2h4v2zm0-4H7v-2h4v2zm0-4H7V6h4v2zm6 8h-4v-2h4v2zm0-4h-4v-2h4v2zm0-4h-4V6h4v2z"/>'
      },
      {
        title: 'Cold-Start Onboarding',
        desc: 'Tuwa starts useful on day one \u2014 no weeks of baseline data required.',
        href: '/features/cold-start',
        iconSvg: '<path d="M7 2v11h3v9l7-12h-4l4-8z"/>'
      },
      {
        title: 'Coach + Athlete',
        desc: 'Real-time recovery visibility and prescribed workouts for your whole team.',
        href: '/features/coaching',
        iconSvg: '<path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>'
      }
    ];

    // --- Compute pointer angle relative to wheel center ---
    function getAngle(e) {
      var rect = svgEl.getBoundingClientRect();
      var scaleX = 480 / rect.width;
      var scaleY = 480 / rect.height;
      var dx = (e.clientX - rect.left) * scaleX - CX;
      var dy = (e.clientY - rect.top) * scaleY - CY;
      return Math.atan2(dy, dx) * (180 / Math.PI);
    }

    // --- Apply rotation: arcs rotate, labels translate to rotated positions, buttons reposition ---
    function setWheelRotation(rotation) {
      currentRotation = rotation;
      // Arcs orbit around center
      arcsGroup.setAttribute('transform', 'rotate(' + rotation + ', ' + CX + ', ' + CY + ')');
      // Labels: compute each label's new position from rotation, translate there (stays upright)
      var rad = rotation * DEG2RAD;
      var cosR = Math.cos(rad);
      var sinR = Math.sin(rad);
      billboards.forEach(function(g) {
        var ox = parseFloat(g.dataset.x);
        var oy = parseFloat(g.dataset.y);
        var dx = ox - CX;
        var dy = oy - CY;
        var tx = (dx * cosR - dy * sinR) - dx;
        var ty = (dx * sinR + dy * cosR) - dy;
        g.setAttribute('transform', 'translate(' + tx + ', ' + ty + ')');
      });

      layoutSegmentButtons(rotation);
    }

    // --- Reposition absolute buttons to follow arc midpoints ---
    var segBtns = wheel.querySelectorAll('.wheel-segment-btn');

    function layoutSegmentButtons(rotation) {
      segBtns.forEach(function(btn, i) {
        var angleDeg = -90 + i * SEGMENT_ANGLE + rotation;
        var rad = angleDeg * DEG2RAD;
        var x = CX + Math.cos(rad) * MID_RADIUS;
        var y = CY + Math.sin(rad) * MID_RADIUS;
        btn.style.left = (x / 480 * 100) + '%';
        btn.style.top = (y / 480 * 100) + '%';
      });
    }

    // --- Pointer Events drag handlers (on container to include buttons) ---
    wheel.addEventListener('pointerdown', function(e) {
      if (e.target.closest('.wheel-center, .wheel-center-content, a')) return;
      isDragging = true;
      wheel.setPointerCapture(e.pointerId);
      lastAngle = getAngle(e);
      velocitySamples = [];
      dragDistance = 0;
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    });

    wheel.addEventListener('pointermove', function(e) {
      if (!isDragging) return;
      var angle = getAngle(e);
      var delta = angle - lastAngle;
      if (delta > 180) delta -= 360;
      if (delta < -180) delta += 360;
      lastAngle = angle;
      currentRotation += delta;
      dragDistance += Math.abs(delta);
      setWheelRotation(currentRotation);
      velocitySamples.push({ angle: currentRotation, time: performance.now() });
      if (velocitySamples.length > 3) velocitySamples.shift();
    });

    wheel.addEventListener('pointerup', function() {
      if (!isDragging) return;
      isDragging = false;
      if (dragDistance < 5) return;
      applyInertiaAndSnap();
    });

    // --- Inertia and snap ---
    function applyInertiaAndSnap() {
      if (reducedMotion || velocitySamples.length < 2) {
        snapToNearest();
        return;
      }
      var first = velocitySamples[0];
      var last = velocitySamples[velocitySamples.length - 1];
      var dt = last.time - first.time;
      var velocity = dt > 0 ? (last.angle - first.angle) / dt : 0;
      var DECAY = 0.92;
      var FRAME_MS = 16.67;
      var MAX_OVERSHOOT = 30;

      function inertiaFrame() {
        velocity *= DECAY;
        currentRotation += velocity * FRAME_MS;
        var nearest = Math.round(currentRotation / SEGMENT_ANGLE) * SEGMENT_ANGLE;
        if (Math.abs(currentRotation - nearest) > MAX_OVERSHOOT) {
          currentRotation = nearest + (currentRotation > nearest ? MAX_OVERSHOOT : -MAX_OVERSHOOT);
          velocity = 0;
        }
        setWheelRotation(currentRotation);
        if (Math.abs(velocity) > 0.05) {
          rafId = requestAnimationFrame(inertiaFrame);
        } else {
          rafId = null;
          snapToNearest();
        }
      }
      rafId = requestAnimationFrame(inertiaFrame);
    }

    function snapToNearest() {
      var nearest = Math.round(currentRotation / SEGMENT_ANGLE) * SEGMENT_ANGLE;
      currentRotation = nearest;
      var idx = (((Math.round(-nearest / SEGMENT_ANGLE)) % 5) + 5) % 5;
      setWheelRotation(nearest);
      updateActive(idx);
    }

    // --- Click-to-select: segment buttons ---
    segBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (dragDistance > 5) { dragDistance = 0; return; }
        var idx = parseInt(btn.getAttribute('data-index'), 10);
        rotateTo(idx);
      });
    });

    // Direct clicks on SVG arc paths
    var arcPaths = wheel.querySelectorAll('.wheel-arc');
    arcPaths.forEach(function(arc) {
      arc.addEventListener('click', function() {
        if (dragDistance > 5) { dragDistance = 0; return; }
        var idx = parseInt(arc.getAttribute('data-index'), 10);
        rotateTo(idx);
      });
    });

    function rotateTo(idx) {
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
      var targetRotation = -idx * SEGMENT_ANGLE;
      var delta = targetRotation - currentRotation;
      while (delta > 180) delta -= 360;
      while (delta < -180) delta += 360;
      currentRotation = currentRotation + delta;
      setWheelRotation(currentRotation);
      updateActive(idx);
    }

    // --- Keyboard navigation ---
    wheel.addEventListener('keydown', function(e) {
      if (e.target.closest('a, input, textarea, select')) return;
      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        e.preventDefault();
        var dir = e.key === 'ArrowRight' ? 1 : -1;
        var newIdx = ((activeIndex + dir) % 5 + 5) % 5;
        rotateTo(newIdx);
      }
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        window.location.href = features[activeIndex].href;
      }
    });

    // --- Update active segment state + center content ---
    function updateActive(idx) {
      activeIndex = idx;

      arcPaths.forEach(function(arc, i) {
        arc.classList.toggle('is-active', i === idx);
      });

      wheel.querySelectorAll('.wheel-segment-content').forEach(function(g, i) {
        g.classList.toggle('is-active', i === idx);
      });
      wheel.querySelectorAll('.wheel-segment-icon').forEach(function(icon, i) {
        icon.classList.toggle('is-active', i === idx);
      });
      wheel.querySelectorAll('.wheel-segment-label').forEach(function(lbl, i) {
        lbl.classList.toggle('is-active', i === idx);
      });

      segBtns.forEach(function(btn, i) {
        btn.setAttribute('aria-pressed', i === idx ? 'true' : 'false');
      });

      var f = features[idx];
      if (reducedMotion) {
        setCenterContent(f);
      } else {
        centerContent.style.opacity = '0';
        setTimeout(function() {
          setCenterContent(f);
          centerContent.style.opacity = '1';
        }, 75);
      }
    }

    function setCenterContent(f) {
      var iconEl = centerContent.querySelector('svg');
      if (iconEl && f.iconSvg) {
        while (iconEl.firstChild) { iconEl.removeChild(iconEl.firstChild); }
        var temp = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        temp.innerHTML = f.iconSvg;
        while (temp.firstChild) { iconEl.appendChild(temp.firstChild); }
      }
      var titleEl = centerContent.querySelector('.wheel-center-title');
      if (titleEl) titleEl.textContent = f.title;
      var descEl = centerContent.querySelector('.wheel-center-desc');
      if (descEl) descEl.textContent = f.desc;
      var linkEl = centerContent.querySelector('.wheel-center-link');
      if (linkEl) {
        linkEl.href = f.href;
        linkEl.setAttribute('aria-label', 'Explore ' + f.title);
      }
    }

  })();
</script>
