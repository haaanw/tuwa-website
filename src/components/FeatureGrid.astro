<!-- Feature Grid section — 5 cards linking to Phase 3 feature deep-dive pages -->
<!-- Feature page links activate in Phase 3 -->

<section class="section-spaced">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Section title -->
    <h2
      class="text-center"
      style="
        font-size: var(--text-heading);
        font-weight: 600;
        line-height: var(--leading-heading);
        letter-spacing: var(--tracking-heading);
        color: var(--color-text-1);
        margin-bottom: var(--space-xl);
      "
    >
      Everything you need to train without guessing
    </h2>

    <!-- Feature bento grid: hero (Recovery Scoring) spans 2col x 2row on desktop -->
    <ul class="bento-grid" role="list">

      <!-- Card 1: Recovery Scoring — hero card spanning 2 columns x 2 rows -->
      <li style="grid-area: recovery;" data-animate data-animate-delay="0ms">
        <a
          href="/features/recovery-scoring"
          class="feature-card bento-hero-card block"
        >
          <!-- Heart / Recovery icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <span style="font-size: var(--text-label); color: var(--color-text-3); letter-spacing: var(--tracking-label); text-transform: uppercase;">RECOVERY</span>
          <span style="font-size: var(--text-body); font-weight: 600; color: var(--color-text-1);">Recovery Scoring</span>
          <span style="font-size: var(--text-body); color: var(--color-text-2);">HRV, sleep, heart rate, and training context synthesized into one daily readiness number.</span>
        </a>
      </li>

      <!-- Card 2: Workload Tracking -->
      <li style="grid-area: workload;" data-animate data-animate-delay="100ms">
        <a
          href="/features/workload-tracking"
          class="feature-card block"
        >
          <!-- Bar chart / Load icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <rect x="2" y="14" width="4" height="8" rx="1"/>
            <rect x="9" y="9" width="4" height="13" rx="1"/>
            <rect x="16" y="4" width="4" height="18" rx="1"/>
          </svg>
          <span style="font-size: var(--text-label); color: var(--color-text-3); letter-spacing: var(--tracking-label); text-transform: uppercase;">LOAD</span>
          <span style="font-size: var(--text-body); font-weight: 600; color: var(--color-text-1);">Workload Tracking</span>
          <span style="font-size: var(--text-body); color: var(--color-text-2);">Multi-factor fatigue tracking and load spike detection keep you in the optimal zone.</span>
        </a>
      </li>

      <!-- Card 3: Smart Templates -->
      <li style="grid-area: templates;" data-animate data-animate-delay="200ms">
        <a
          href="/features/smart-templates"
          class="feature-card block"
        >
          <!-- Clipboard / Templates icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7-1c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-1 14H7v-2h4v2zm0-4H7v-2h4v2zm0-4H7V6h4v2zm6 8h-4v-2h4v2zm0-4h-4v-2h4v2zm0-4h-4V6h4v2z"/>
          </svg>
          <span style="font-size: var(--text-label); color: var(--color-text-3); letter-spacing: var(--tracking-label); text-transform: uppercase;">TRAINING</span>
          <span style="font-size: var(--text-body); font-weight: 600; color: var(--color-text-1);">Smart Templates</span>
          <span style="font-size: var(--text-body); color: var(--color-text-2);">Prescribed workouts with target sets, weight, and rep goals built in.</span>
        </a>
      </li>

      <!-- Card 4: Cold-Start Onboarding -->
      <li style="grid-area: cold-start;" data-animate data-animate-delay="300ms">
        <a
          href="/features/cold-start"
          class="feature-card block"
        >
          <!-- Lightning bolt / Cold-start icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M7 2v11h3v9l7-12h-4l4-8z"/>
          </svg>
          <span style="font-size: var(--text-label); color: var(--color-text-3); letter-spacing: var(--tracking-label); text-transform: uppercase;">ONBOARDING</span>
          <span style="font-size: var(--text-body); font-weight: 600; color: var(--color-text-1);">Cold-Start Onboarding</span>
          <span style="font-size: var(--text-body); color: var(--color-text-2);">Tuwa starts useful on day one — no weeks of baseline data required.</span>
        </a>
      </li>

      <!-- Card 5: Coach + Athlete -->
      <li style="grid-area: coaching;" data-animate data-animate-delay="400ms">
        <a
          href="/features/coaching"
          class="feature-card block"
        >
          <!-- Two people / Coaching icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent)" aria-hidden="true">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
          <span style="font-size: var(--text-label); color: var(--color-text-3); letter-spacing: var(--tracking-label); text-transform: uppercase;">COACHING</span>
          <span style="font-size: var(--text-body); font-weight: 600; color: var(--color-text-1);">Coach + Athlete</span>
          <span style="font-size: var(--text-body); color: var(--color-text-2);">Real-time recovery visibility and prescribed workouts for your whole team.</span>
        </a>
      </li>

    </ul>
  </div>
</section>
